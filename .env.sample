# danny-demo-platform — Environment Variables

# Domain
NEXT_PUBLIC_APP_DOMAIN=dontsweatitdanny.com
NEXT_PUBLIC_PLATFORM_ORIGIN=https://platform.dontsweatitdanny.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs used by the client (must be NEXT_PUBLIC_*)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=

# Paywall behavior (unused — kept for reference; gate is subscription-only now)

# Admin (optional)
ADMIN_SECRET=

# Debug (optional)
DEBUG_SECRET=

# Vercel integration (needed by publish-demo endpoint)
VERCEL_TOKEN=
DEMO_WILDCARD_DOMAIN=demos.dontsweatitdanny.com
